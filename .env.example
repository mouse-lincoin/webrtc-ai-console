# packages/host/.env — 复制为 packages/host/.env

# Cursor SDK（Mac 宿主 Agent，可选；无则 host 浏览器侧 echo）
CURSOR_API_KEY=

# 信令 HTTP 端口
HOST_PORT=8787

# 公网/隧道建议设置；join 时客户端须携带相同令牌
ROOM_ACCESS_TOKEN=

# TURN（4G / 对称 NAT）
# TURN_URLS=turn:your-vps.example.com:3478?transport=udp,turn:your-vps.example.com:3478?transport=tcp
# TURN_AUTH_SECRET=your-coturn-static-auth-secret

# CORS：GitHub Pages 或自有前端域名，逗号分隔
# PUBLIC_ORIGIN=https://mouse-lincoin.github.io,http://localhost:5173

# Agent 工作目录（默认 host 进程 cwd）
# AGENT_CWD=/path/to/repo
# AGENT_MODEL_ID=composer-2.5

# packages/client/.env — 连接页默认值（可选）
# VITE_SIGNAL_URL=ws://localhost:8787/ws
# VITE_ROOM_TOKEN=
